      enum device-sensor-dhcp-tftp-srvr-opt {
        value 104;
        description
          "Device sensor DHCP filter-list configured for TFTP server
           option - TFTP is an insecure protocol";
      }
      enum mon-capt-cont-insec-url {
        value 105;
        description
          "Monitor capture with continuous-capture option is using insecure URL";
      }
      enum mon-capt-export-insec-url {
        value 106;
        description
          "Monitor capture buffer is exporting using insecure URL";
      }
      enum ntp-auth-md5-vulnerable {
        value 107;
        description
          "NTP authentication using MD5 - vulnerable to collision attacks
           and should use stronger algorithms";
      }
      enum ntp-auth-key-weak-encr {
        value 108;
        description
          "NTP authentication key configured with weak encryption
           (type 0 or 7) instead of secure type 6 encryption";
      }
      enum ip-scp-sftp-pwd-weak-encr {
        value 109;
        description
          "IP SCP/SFTP password configured with weak encryption
           (type 0, 7 or plain text) instead of secure type 6 encryption";
