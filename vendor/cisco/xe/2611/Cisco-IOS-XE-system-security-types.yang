    description
      "Configuration submode which owns the insecure CLI";
  }

  typedef sys-insec-evt-type {
    type enumeration {
      enum insec-conf {
        value 0;
        description
          "Event to notify of newly added insecure configuration";
      }
      enum insec-warn {
        value 1;
        description
          "Event to notify of insecure configuration allowed when system security mode is secure";
      }
    }
    description
      "System insecure configuration event type";
  }

  grouping sys-insec-info {
    description
      "System insecure configuration information";
    leaf config-cli {
      type string;
      description
        "Specifies the configuration CLI command that has been identified as insecure by the system security process.";
    }
    leaf parent-cli {
      type string;
      description
        "Specifies the parent CLI submode or context from which this configuration command is derived";
    }
    leaf desc {
      type system-security-types-ios-xe-oper:insec-conf-desc;
      description
        "Provides a human-readable description of the configuration CLI command or context";
    }
    leaf module {
      type system-security-types-ios-xe-oper:insec-conf-module;
      description
        "Indicates the software module responsible for the insecure configuration CLI command.";
    }
    leaf reason {
      type system-security-types-ios-xe-oper:insec-conf-reason;
      description
        "Describes the reason why the configuration CLI command has been classified as insecure.";
    }
    leaf remedy {
      type system-security-types-ios-xe-oper:insec-conf-remedy;
      description
        "Specifies the recommended remediation action to address the insecure configuration CLI command.";
    }
    leaf submode {
      type system-security-types-ios-xe-oper:insec-conf-submode;
      description
        "Indicates the specific configuration submode or context in which the CLI command is executed";
    }
  }
}
