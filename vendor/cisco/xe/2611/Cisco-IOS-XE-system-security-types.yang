  }

  typedef insec-conf-submode {
    type enumeration {
      enum sm-unknown {
        value 0;
        description
          "unknown submode";
      }
      enum sm-config {
        value 1;
        description
          "Global configuration submode. It is a top level config submode
           entered via 'config terminal' CLI";
      }
      enum sm-conf-rad-srvr {
        value 2;
        description
          "configure RADIUS server submode";
      }
      enum sm-conf-tac-srvr {
        value 3;
        description
          "configure TACACS server submode";
      }
      enum sm-sg-radius {
        value 4;
        description
          "SG-RADIUS submode";
      }
      enum sm-radius-da-locsvr {
        value 5;
        description
          "RADIUS-DA local server submode";
      }
      enum sm-conf-ldap-srvr {
        value 6;
        description
          "configure LDAP server submode";
      }
      enum sm-radius-sesm-locsvr {
        value 7;
        description
          "RADIUS SES manager local server submode";
      }
      enum sm-radius-proxy-locsvr {
        value 8;
        description
          "RADIUS proxy local server submode";
      }
      enum sm-radius-policy-device-locsvr {
        value 9;
        description
          "RADIUS policy device local server submode";
      }
      enum sm-sg-tacacs-plus {
        value 10;
        description
          "SG-TACACS+ submode";
      }
      enum sm-key-chain-tcp-key {
        value 11;
        description
          "key-chain TCP key submode";
      }
      enum sm-line {
        value 12;
        description
          "line submode";
      }
      enum sm-router {
        value 13;
        description
          "router submode";
      }
      enum sm-eap-mprofile-mode {
        value 14;
        description
          "EAP managed profile submode";
      }
      enum sm-dot1x-cred-mode {
        value 15;
        description
          "DOT1X credential submode";
      }
      enum sm-eap-profile-mode {
        value 16;
        description
          "EAP profile submode";
      }
      enum sm-param-submode {
        value 17;
        description
          "parameter submode";
      }
      enum sm-view {
        value 18;
        description
          "view submode";
      }
      enum sm-tls-profile {
        value 19;
        description
          "TLS profile submode";
      }
      enum sm-dspfarmprofile {
        value 20;
        description
          "DSPFARM profile submode";
      }
      enum sm-key-chain-key {
        value 21;
        description
          "key-chain-key submode";
      }
      enum sm-key-chain-macsec-key {
        value 22;
        description
          "key-chain MACSEC key submode";
      }
      enum sm-voiceclass {
        value 23;
        description
          "voice class submode";
      }
      enum sm-cm-fallback {
        value 24;
        description
          "CM fallback submode";
      }
      enum sm-sip-ua {
        value 25;
        description
          "SIP-UA submode";
      }
      enum sm-ipv6-pmipv6-domain {
        value 26;
        description
          "IPv6-pm IPv6-domain submode";
      }
      enum sm-ipv6-pmipv6-lma-mag {
        value 27;
        description
          "IPv6-pm IPv6 Local Mobility Anchor - Mobile Access Gateway submode";
      }
      enum sm-ipv6-pmipv6-mag-lma {
        value 28;
        description
          "IPv6-pm IPv6 Mobile Access Gateway -  Local Mobility Anchor submode";
