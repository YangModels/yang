   reference
     "RFC 9552: Distribution of Link-State and Traffic Engineering
     Information Using BGP.";
 }

 identity bgp-ls-topo-attr-node-name {
   base "bgp-ls-topo-attr-type";
   description
     "BGP-LS TLV 1026. Symbolic name of the router node";
   reference
     "RFC 9552: Distribution of Link-State and Traffic Engineering
     Information Using BGP.";
 }

 identity bgp-ls-topo-attr-isis-area-identifier {
   base "bgp-ls-topo-attr-type";
   description
     "BGP-LS TLV 1027. Area address of an ISIS area";
   reference
     "RFC 9552: Distribution of Link-State and Traffic Engineering
     Information Using BGP.";
 }

 identity bgp-ls-topo-attr-local-ipv4-routerid {
   base "bgp-ls-topo-attr-type";
   description
     "BGP-LS TLV 1028. Auxiliary Router-ID used by the IGP";
