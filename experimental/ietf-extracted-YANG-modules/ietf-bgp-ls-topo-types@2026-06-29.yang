     "RFC 9514: Border Gateway Protocol - Link State (BGP-LS)
      Extensions for Segment Routing over IPv6 (SRv6).";
 }

 identity bgp-ls-topo-attr-fad {
   base "bgp-ls-topo-attr-type";
   description
     "BGP-LS TLV 1039. Definition of Flexible Algorithms
